# Google Maps / Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Claude API (for vision/garment selection)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Replicate (virtual try-on, free trial)
REPLICATE_API_TOKEN=your_replicate_token

# Lob (postcard mailing, free trial = 300 postcards)
LOB_API_KEY=your_lob_test_api_key

# Optional: Stannp as Lob alternative
STANNP_API_KEY=your_stannp_api_key

# Higgsfield (connected via MCP, no key needed if using Claude Code)
HIGGSFIELD_API_KEY=optional_for_standalone_use
