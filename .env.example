# ─── STEP 1: Store Discovery — pick ONE (Yelp recommended, no card needed) ───

# OPTION A: Yelp Fusion API — FREE 500 searches/day, NO credit card
# Sign up: https://docs.developer.yelp.com/
# Dashboard → My Apps → Create App → copy "API Key"
YELP_API_KEY=your_yelp_api_key_here

# OPTION B: OpenStreetMap — 100% FREE, no signup at all
# No key needed! Just set --source osm when running the pipeline
# Works best in major cities (US, UK, EU)

# OPTION C: Google Maps — needs payment verification (skip if you want free)
# Sign up: https://console.cloud.google.com → Enable Places API + Geocoding API
GOOGLE_MAPS_API_KEY=

# ─── STEP 2: Groq AI Vision — 100% FREE, no credit card ─────────────────────
# Sign up: https://console.groq.com
# Left sidebar → API Keys → Create API Key → copy it
GROQ_API_KEY=your_groq_api_key_here

# ─── STEP 3: Replicate — Virtual Try-On + Video (free trial credits) ─────────
# Sign up: https://replicate.com
# Top right → avatar → Account Settings → API Tokens → copy it
REPLICATE_API_TOKEN=your_replicate_token_here

# ─── STEP 4: Lob — Physical postcard mailing (300 free TEST postcards) ───────
# Sign up: https://lob.com
# Settings → API Keys → copy the TEST key (starts with test_live_...)
LOB_API_KEY=your_lob_test_key_here

# ─── OPTIONAL: Email follow-up via Gmail (free 500/day) ──────────────────────
# Enable 2FA on Gmail → Security → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_here
FROM_NAME=Your Agency Name
FROM_EMAIL=your_gmail@gmail.com

# ─── YOUR AGENCY DETAILS (shows on postcards + emails) ───────────────────────
AGENCY_NAME=Your Agency Name
AGENCY_WEBSITE=youragency.com
AGENCY_EMAIL=hello@youragency.com
