# ─── STEP 1: Google Maps API (FREE — $200/month credit) ──────────────────────
# Sign up: https://console.cloud.google.com
# Enable: "Places API" and "Geocoding API"
# Create credentials → API Key → copy it here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── STEP 2: Groq API (100% FREE — no credit card needed) ────────────────────
# Sign up: https://console.groq.com
# Go to: API Keys → Create API Key → copy it here
GROQ_API_KEY=your_groq_api_key_here

# ─── STEP 3: Replicate (FREE trial credits) ───────────────────────────────────
# Sign up: https://replicate.com
# Go to: Account Settings → API Tokens → copy it here
REPLICATE_API_TOKEN=your_replicate_token_here

# ─── STEP 4: Lob (300 FREE test postcards) ───────────────────────────────────
# Sign up: https://lob.com
# Go to: Settings → API Keys → copy TEST key (starts with test_live_...)
LOB_API_KEY=your_lob_test_api_key_here

# ─── OPTIONAL: Email follow-up (Gmail SMTP — free) ───────────────────────────
# Use a Gmail account. Enable 2FA, then create an App Password:
# Google Account → Security → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_NAME=Your Agency Name
FROM_EMAIL=your_gmail@gmail.com

# ─── YOUR AGENCY DETAILS (shows on postcards) ─────────────────────────────────
AGENCY_NAME=Your Agency Name
AGENCY_WEBSITE=youragency.com
AGENCY_EMAIL=hello@youragency.com
